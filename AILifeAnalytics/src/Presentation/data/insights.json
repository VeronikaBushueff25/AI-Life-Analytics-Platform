  {
    "Id": "cd0fc2b3-f785-4672-bd0d-bbf88e8254b8",
    "Date": "2026-03-20T11:03:32.3651985Z",
    "Content": "1. \u041F\u0430\u0442\u0442\u0435\u0440\u043D: \u043F\u0440\u0438 \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u043E\u0439 \u0434\u043B\u0438\u043D\u0435 \u0441\u043D\u0430 (8 \u0447) \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435 \u043A\u043E\u043B\u0435\u0431\u043B\u0435\u0442\u0441\u044F \u043E\u0442 6 \u0434\u043E 10 \u2014 \u043A\u043B\u044E\u0447\u0435\u0432\u043E\u0439 \u0444\u0430\u043A\u0442\u043E\u0440 \u043D\u0435 \u0441\u043E\u043D, \u0430 \u0441\u043E\u0434\u0435\u0440\u0436\u0430\u043D\u0438\u0435 \u0434\u043D\u044F.  \n2. \u041F\u0430\u0442\u0442\u0435\u0440\u043D: \u0444\u043E\u043A\u0443\u0441 \u043D\u0438\u0436\u0435 \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F \u043D\u0430 1,2 \u0431\u0430\u043B\u043B\u0430 \u043A\u0430\u0436\u0434\u044B\u0439 \u0434\u0435\u043D\u044C \u2014 \u0437\u043D\u0430\u0447\u0438\u0442, \u0440\u0435\u0441\u0443\u0440\u0441 \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u0442\u0440\u0430\u0442\u0438\u0442\u0441\u044F \u0431\u044B\u0441\u0442\u0440\u0435\u0435, \u0447\u0435\u043C \u0432\u043E\u0441\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F.  \n3. \u041F\u0430\u0442\u0442\u0435\u0440\u043D: \u0440\u0430\u0431\u043E\u0447\u0435\u0435 \u0432\u0440\u0435\u043C\u044F \u0432\u0441\u0435\u0433\u043E 4,5 \u0447, \u043D\u043E \u0432 \u0434\u0435\u043D\u044C \u043F\u0430\u0434\u0435\u043D\u0438\u044F \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u044F (17.03) \u043E\u043D\u043E \u0431\u044B\u043B\u043E \u0440\u0430\u0437\u0431\u0438\u0442\u043E \u043D\u0430 \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0435 \u043A\u0443\u0441\u043A\u0438 \u2014 \u0444\u0440\u0430\u0433\u043C\u0435\u043D\u0442\u0430\u0446\u0438\u044F \u0443\u0441\u0438\u043B\u0438\u0432\u0430\u0435\u0442 \u0443\u0441\u0442\u0430\u043B\u043E\u0441\u0442\u044C.\n\n\u0420\u0435\u043A\u043E\u043C\u0435\u043D\u0434\u0430\u0446\u0438\u0438: \u0432\u0435\u0447\u0435\u0440\u043E\u043C \u043D\u0430\u043A\u0430\u043D\u0443\u043D\u0435 \u043D\u0430\u043F\u0440\u044F\u0436\u0451\u043D\u043D\u043E\u0433\u043E \u0434\u043D\u044F \u043F\u043B\u0430\u043D\u0438\u0440\u0443\u0439 10-\u043C\u0438\u043D\u0443\u0442\u043D\u0443\u044E \u00AB\u0442\u043E\u0447\u043A\u0443 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u044F\u00BB (\u043F\u0440\u043E\u0433\u0443\u043B\u043A\u0430 \u0431\u0435\u0437 \u044D\u043A\u0440\u0430\u043D\u0430), \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u0438 \u0441\u0430\u043C\u044B\u0435 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0438\u0435 \u0437\u0430\u0434\u0430\u0447\u0438 \u0432 \u043F\u0435\u0440\u0432\u044B\u0435 2 \u0447 \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u0434\u044A\u0451\u043C\u0430 \u0438 \u0437\u0430\u0449\u0438\u0449\u0430\u0439 \u044D\u0442\u043E \u043E\u043A\u043D\u043E \u043E\u0442 \u043F\u0435\u0440\u0435\u043F\u0438\u0441\u043E\u043A; \u0432 \u0434\u043D\u0438, \u043A\u043E\u0433\u0434\u0430 \u043D\u0430\u0441\u0442\u0440\u043E\u0435\u043D\u0438\u0435 \u22647, \u0443\u043C\u0435\u043D\u044C\u0448\u0430\u0439 \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u043E \u043F\u0435\u0440\u0435\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0439: \u0440\u0430\u0431\u043E\u0442\u0430\u0439 2 \u0431\u043B\u043E\u043A\u0430 \u043F\u043E 90 \u043C\u0438\u043D \u0441 15-\u043C\u0438\u043D\u0443\u0442\u043D\u044B\u043C \u043F\u0435\u0440\u0435\u0440\u044B\u0432\u043E\u043C \u043C\u0435\u0436\u0434\u0443 \u043D\u0438\u043C\u0438, \u043D\u043E \u043D\u0435 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0439 \u043C\u0435\u0441\u0441\u0435\u043D\u0434\u0436\u0435\u0440\u044B \u0434\u043E \u043E\u0431\u0435\u0434\u0430.",
